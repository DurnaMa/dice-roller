<!DOCTYPE html>
<html lang="en">
  <head>
    {% block head %}
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <link rel="stylesheet" href="{{ url_for('static', filename='css/main.css') }}" />
      <title>{% block title %}{% endblock %}-- Dice-Roller</title>
    {% endblock head %}
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="felx text-center">
      <a href="{{ url_for('home') }}">
        <h1 class="text-4xl font-bold">Awesome Dice Roller</h1>
      </a>
    </header>

    <main class="flex-grow flex items-center justify-center">{% block content %}{% endblock %}</main>

    <div id="footer" class="text-center py-4 text-gray-500">
      {% block footer %}
        &copy; Copyright 2026 by &nbsp; {% block author %}{{ _author | default("You") }}{% endblock %}
      {% endblock %}
    </div>
  </body>
</html>
